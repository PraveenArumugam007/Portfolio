---
import '../styles/global.css';

const pageTitle = 'Praveen A | Software Engineer';
const pageDescription = 'Praveen A is an Angular-focused Software Engineer with 3+ years of experience building scalable enterprise applications and performance-driven SPAs.';
const siteUrl = 'https://praveena.github.io/Portfolio';
const basePath = import.meta.env.BASE_URL;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Praveen A',
  jobTitle: 'Software Engineer | Frontend Developer',
  url: siteUrl,
  sameAs: [],
  description: pageDescription,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Ettaiyapuram',
    addressCountry: 'IN',
  },
  email: 'mailto:praveenrumugam.job@gmail.com'
};
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content="Angular Developer, Software Engineer, Frontend Developer, TypeScript, RxJS, Node.js, PostgreSQL, PWA, Performance Optimization" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <link rel="canonical" href={siteUrl} />
    <script type="application/ld+json">
      {JSON.stringify(structuredData)}
    </script>
  </head>
  <body>
    <header class="toolbar">
      <div class="toolbar-inner">
        <a class="brand" href="#home">Praveen A</a>
        <button class="toolbar-toggle" id="toolbar-toggle" type="button" aria-label="Open navigation menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <nav class="toolbar-nav" id="toolbar-nav" aria-label="Primary navigation">
          <button class="drawer-close" id="toolbar-close" type="button" aria-label="Close navigation menu">×</button>
          <a href="#summary">Summary</a>
          <a href="#skills">Skills</a>
          <a href="#experience">Experience</a>
          <a href="#projects">Projects</a>
          <a href="#education">Education</a>
          <a href="#awards">Awards</a>
          <a href="#contact">Contact</a>
        </nav>
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
          <span class="theme-toggle-track">
            <span class="theme-toggle-thumb" id="theme-toggle-thumb">
              <span class="theme-toggle-symbol">🌙</span>
            </span>
          </span>
        </button>
      </div>
      <div class="toolbar-backdrop" id="toolbar-backdrop" tabindex="-1"></div>
    </header>
    <main class="container">
      <section class="hero fade-in" id="home">
        <div class="hero-image">
          <img src={`${basePath}profile.jpeg`} alt="Profile photo of Praveen A" />
        </div>
        <div class="hero-content">
          <span class="subtle-label">Software Engineer • Angular Specialist</span>
          <h1 class="hero-title">
            Building high-performance Angular experiences for commerce and marketing products.
          </h1>
          <p class="hero-copy">
            Angular Developer with 3+ years of experience building scalable SPAs using Angular 15+, TypeScript, RxJS, and Angular Material. Proven track record of reducing page load times by 70%, cutting production bugs by 30%, and shipping 12+ features per sprint in Agile teams.
          </p>
          <div class="cta-group">
            <a class="button" href={`${basePath}resume.pdf`} download>Download Resume</a>
            <a class="button-secondary" href="#contact">Contact Me</a>
          </div>
        </div>
      </section>

      <section class="section fade-in" id="summary">
        <div class="section-title"><h2>Professional Summary</h2></div>
        <div class="experience-highlight">
          <div class="experience-badge">
            <span>3+</span>
            <span>Years</span>
          </div>
          <div class="card experience-copy">
            <p>
              UI/UX-minded Angular Developer with 3+ years of experience building scalable SPAs using Angular 15+, TypeScript, RxJS, and Angular Material. Proven track record of reducing page load times by 70%, cutting production bugs by 30%, and delivering 12+ features per sprint in Agile teams.
            </p>
            <ul class="card-list">
              <li>Experienced in Node.js, PostgreSQL, REST API & GraphQL integration, and 85%+ unit test coverage with Jest/Jasmine/Karma.</li>
              <li>Delivered reusable front-end architecture while improving accessibility and responsive performance.</li>
              <li>Built high-impact applications for commerce and marketing workflows with international readiness.</li>
            </ul>
            <div class="tag-grid" style="margin-top:24px;">
              <span class="skill-chip">Angular 15+</span>
              <span class="skill-chip">TypeScript</span>
              <span class="skill-chip">RxJS</span>
              <span class="skill-chip">Angular Material</span>
              <span class="skill-chip">Node.js</span>
              <span class="skill-chip">PostgreSQL</span>
            </div>
          </div>
        </div>
      </section>

      <section class="section fade-in" id="skills">
        <div class="section-title"><h2>Skills & Technologies</h2></div>
        <div class="card">
          <div class="tag-grid">
            <span class="skill-chip">Angular 15+</span>
            <span class="skill-chip">TypeScript</span>
            <span class="skill-chip">RxJS</span>
            <span class="skill-chip">Angular Material</span>
            <span class="skill-chip">HTML5</span>
            <span class="skill-chip">CSS3</span>
            <span class="skill-chip">Responsive Design</span>
            <span class="skill-chip">PWA</span>
            <span class="skill-chip">Node.js</span>
            <span class="skill-chip">Express.js</span>
            <span class="skill-chip">REST APIs</span>
            <span class="skill-chip">GraphQL</span>
            <span class="skill-chip">PostgreSQL</span>
            <span class="skill-chip">Sequelize</span>
            <span class="skill-chip">Jest</span>
            <span class="skill-chip">Cypress</span>
            <span class="skill-chip">Git / GitLab</span>
            <span class="skill-chip">CI/CD</span>
            <span class="skill-chip">Agile / Scrum</span>
          </div>
        </div>
      </section>

      <section class="section fade-in" id="experience">
        <div class="section-title"><h2>Professional Experience</h2></div>
        <div class="grid grid-2">
          <article class="card">
            <h3 class="card-title">Centizen, Inc.</h3>
            <p class="card-subtitle">Zenbasket Marketing Portal | Angular 15+, TypeScript, RxJS, REST APIs</p>
            <p class="card-subtitle">Feb 2023 – Present</p>
            <ul class="card-list">
              <li>Launched a marketing portal from scratch as part of a 4-member Angular team, architecting a reusable component library that reduced feature development time by 25%.</li>
              <li>Integrated Razorpay and Stripe payment gateways with multi-currency support, improving checkout conversion by 18%.</li>
              <li>Refactored legacy Angular modules with lazy loading and bundle splitting, achieving a 20% improvement in UI rendering speed.</li>
            </ul>
          </article>
          <article class="card">
            <h3 class="card-title">Centizen, Inc.</h3>
            <p class="card-subtitle">Zenbasket E-commerce Platform | Angular 15+, TypeScript, RxJS, Node.js, PostgreSQL, Sequelize</p>
            <p class="card-subtitle">Jan 2025 – Present</p>
            <ul class="card-list">
              <li>Migrated a large legacy codebase to strict TypeScript, reducing production bugs by 30% and improving overall code robustness.</li>
              <li>Designed and deployed 10+ reusable Angular components, services, and modules adopted across multiple teams.</li>
              <li>Optimized the page load pipeline with modularization and lazy loading, slashing load times from 5s to 1.5s.</li>
              <li>Delivered multilingual i18n support across 4 storefronts and built a real-time web push notification system with Service Workers.</li>
            </ul>
          </article>
        </div>
      </section>

      <section class="section fade-in" id="projects">
        <div class="section-title"><h2>Project Highlights</h2></div>
        <div class="grid grid-2">
          <article class="card">
            <h3 class="card-title">Angular Chat System</h3>
            <p class="card-subtitle">Real-time messaging without WebSockets</p>
            <p>
              Designed a lightweight chat feature using RxJS observables and service workers to deliver instant messaging while reducing infrastructure overhead and keeping the experience smooth on the web.
            </p>
          </article>
          <article class="card">
            <h3 class="card-title">E-commerce Core Modules</h3>
            <p class="card-subtitle">Checkout, order flows, customer management</p>
            <p>
              Architected Angular modules for checkout, purchase management, customer data, and plan workflows, ensuring secure REST and GraphQL data flows from frontend to backend.
            </p>
          </article>
        </div>
      </section>

      <section class="section fade-in" id="education">
        <div class="section-title"><h2>Education</h2></div>
        <div class="card">
          <p>P.S.R Engineering College — Bachelor of Engineering in Computer Science and Engineering</p>
          <p><strong>CGPA:</strong> 8.62</p>
          <p><strong>Graduation:</strong> 2019 – 2023</p>
        </div>
      </section>

      <section class="section fade-in" id="awards">
        <div class="section-title"><h2>Awards & Certifications</h2></div>
        <div class="grid grid-2">
          <article class="card">
            <h3 class="card-title">Industry Recognition</h3>
            <ul class="card-list">
              <li>Outstanding Developer Award — Centizen Inc., 2024</li>
              <li>Recent Treasure Award — Centizen Inc., 2023</li>
            </ul>
          </article>
          <article class="card">
            <h3 class="card-title">Certifications</h3>
            <ul class="card-list">
              <li>JavaScript Certification — Scaler</li>
              <li>Node.js Fundamentals — Scaler</li>
              <li>AI Tools Workshop — Be 10x</li>
            </ul>
          </article>
        </div>
      </section>

      <section class="section fade-in" id="contact">
        <div class="section-title"><h2>Contact</h2></div>
        <div class="grid contact-grid">
          <div class="card contact-panel">
            <div class="contact-item">
              <strong>Location</strong>
              <span>Ettaiyapuram, India</span>
            </div>
            <div class="contact-item">
              <strong>Email</strong>
              <a href="mailto:praveenrumugam.job@gmail.com" class="accent">praveenrumugam.job@gmail.com</a>
            </div>
            <div class="contact-item">
              <strong>Phone</strong>
              <span>+91 7418794326</span>
            </div>
          </div>
          <form class="card contact-form" id="contact-form">
            <h3 class="card-title">Send a message</h3>
            <label class="form-group">
              <span class="form-label">Your name</span>
              <input type="text" name="name" required placeholder="John Doe" class="form-input" />
            </label>
            <label class="form-group">
              <span class="form-label">Your email</span>
              <input type="email" name="email" required placeholder="john@example.com" class="form-input" />
            </label>
            <label class="form-group">
              <span class="form-label">Message</span>
              <textarea name="message" required placeholder="Hi Praveen, I'd like to discuss..." class="form-textarea"></textarea>
            </label>
            <button type="submit" class="button">Send message</button>
            <p class="form-note">This will send your message directly when the form is submitted.</p>
            <p class="form-feedback" id="form-feedback"></p>
          </form>
        </div>
      </section>
    </main>
    <footer class="footer">Built with Astro · Portfolio designed for readability, SEO, and performance.</footer>
    <script type="module">
      const form = document.getElementById('contact-form');
      const feedback = document.getElementById('form-feedback');
      const themeToggle = document.getElementById('theme-toggle');
      const themeToggleSymbol = document.querySelector('.theme-toggle-symbol');
      const toolbarToggle = document.getElementById('toolbar-toggle');
      const toolbarClose = document.getElementById('toolbar-close');
      const toolbarNav = document.getElementById('toolbar-nav');
      const toolbarBackdrop = document.getElementById('toolbar-backdrop');
      const serviceId = 'YOUR_EMAILJS_SERVICE_ID';
      const templateId = 'YOUR_EMAILJS_TEMPLATE_ID';
      const publicKey = 'YOUR_EMAILJS_PUBLIC_KEY';
      const emailjsUrl = 'https://api.emailjs.com/api/v1.0/email/send';
      const themeStorageKey = 'portfolio-theme';

      const revealElements = document.querySelectorAll('.fade-in, .card, .section-title, .contact-item, .card-list li, .experience-badge, .metric-bar');
      const revealObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('visible');
          if (entry.target.classList.contains('experience-badge')) {
            entry.target.classList.add('animated');
          }
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.16, rootMargin: '0px 0px -10% 0px' });

      revealElements.forEach((element, index) => {
        element.style.setProperty('--reveal-delay', `${(index % 10) * 60}ms`);
        revealObserver.observe(element);
      });

      const cursorDot = document.createElement('div');
      const cursorOutline = document.createElement('div');
      cursorDot.className = 'cursor-dot';
      cursorOutline.className = 'cursor-outline';
      document.body.append(cursorDot, cursorOutline);

      let mouseX = window.innerWidth / 2;
      let mouseY = window.innerHeight / 2;
      let dotX = mouseX;
      let dotY = mouseY;
      let outlineX = mouseX;
      let outlineY = mouseY;

      function animateCursor() {
        dotX += (mouseX - dotX) * 0.35;
        dotY += (mouseY - dotY) * 0.35;
        outlineX += (mouseX - outlineX) * 0.17;
        outlineY += (mouseY - outlineY) * 0.17;

        cursorDot.style.transform = `translate3d(${dotX}px, ${dotY}px, 0)`;
        cursorOutline.style.transform = `translate3d(${outlineX}px, ${outlineY}px, 0)`;
        requestAnimationFrame(animateCursor);
      }

      animateCursor();

      document.addEventListener('mousemove', (event) => {
        mouseX = event.clientX;
        mouseY = event.clientY;
      });

      const hoverTargets = document.querySelectorAll('a, button, input, textarea, img, .button, .button-secondary, .toolbar-toggle, .theme-toggle, .toolbar-nav a');
      hoverTargets.forEach((target) => {
        target.addEventListener('mouseenter', () => document.body.classList.add('cursor-hover'));
        target.addEventListener('mouseleave', () => document.body.classList.remove('cursor-hover'));
      });

      function applyTheme(theme) {
        const isLight = theme === 'light';
        document.documentElement.classList.toggle('theme-light', isLight);
        document.documentElement.classList.toggle('theme-dark', !isLight);
        if (themeToggle) {
          themeToggle.classList.toggle('is-light', isLight);
          themeToggle.setAttribute('aria-label', `Switch to ${isLight ? 'dark' : 'light'} mode`);
        }
        if (themeToggleSymbol) {
          themeToggleSymbol.textContent = isLight ? '☀️' : '🌙';
        }
        localStorage.setItem(themeStorageKey, theme);
      }

      function initTheme() {
        const storedTheme = localStorage.getItem(themeStorageKey);
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = storedTheme || (prefersDark ? 'dark' : 'light');
        applyTheme(theme);
      }

      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          const isLight = document.documentElement.classList.contains('theme-light');
          applyTheme(isLight ? 'dark' : 'light');
        });
      }

      function toggleNav(isOpen) {
        if (!toolbarNav || !toolbarBackdrop) return;
        toolbarNav.classList.toggle('is-open', isOpen);
        toolbarBackdrop.classList.toggle('is-open', isOpen);
        document.body.style.overflow = isOpen ? 'hidden' : '';
      }

      if (toolbarToggle) {
        toolbarToggle.addEventListener('click', () => toggleNav(true));
      }

      if (toolbarClose) {
        toolbarClose.addEventListener('click', () => toggleNav(false));
      }

      if (toolbarBackdrop) {
        toolbarBackdrop.addEventListener('click', () => toggleNav(false));
      }

      document.querySelectorAll('.toolbar-nav a').forEach((link) => {
        link.addEventListener('click', () => toggleNav(false));
      });

      initTheme();

      function showFeedback(message, isError = false) {
        if (feedback) {
          feedback.textContent = message;
          feedback.style.color = isError ? '#ff8b92' : '#8df7d6';
        }
      }

      if (form) {
        form.addEventListener('submit', async (event) => {
          event.preventDefault();
          if ([serviceId, templateId, publicKey].some((value) => value.includes('YOUR_'))) {
            showFeedback('Email service is not configured yet. Update the EmailJS IDs in the page script.', true);
            return;
          }

          const data = new FormData(form);
          const payload = {
            service_id: serviceId,
            template_id: templateId,
            user_id: publicKey,
            template_params: {
              from_name: data.get('name')?.toString() || '',
              from_email: data.get('email')?.toString() || '',
              message: data.get('message')?.toString() || '',
              to_email: 'praveenrumugam.job@gmail.com',
            },
          };

          try {
            const response = await fetch(emailjsUrl, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });

            if (response.ok) {
              showFeedback('Message sent successfully. Thank you!');
              form.reset();
            } else {
              showFeedback('There was an issue sending your message. Please try again later.', true);
            }
          } catch (error) {
            showFeedback('Network error while sending your message. Check your connection.', true);
          }
        });
      }
    </script>
  </body>
</html>
