# EmailJS Credentials
# Sign up at https://www.emailjs.com/ and copy these from your dashboard
# All three variables are required for the contact form to work.
#
# IMPORTANT: Prefix must be PUBLIC_ so Astro exposes them to the browser at build time.

PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here
PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id_here
PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here
